{
  "manifest_version": 3,
  "name": "Mosaic",
  "version": "1.0.0",
  "description": "Fast keyboard-driven tab overview interface with thumbnails",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "tabCapture",
    "favicon"
  ],
  "icons": {
    "16": "mosaic-logo.svg",
    "32": "mosaic-logo.svg",
    "48": "mosaic-logo.svg",
    "128": "mosaic-logo.svg"
  },
  "action": {
    "default_icon": {
      "16": "mosaic-logo.svg",
      "32": "mosaic-logo.svg",
      "48": "mosaic-logo.svg",
      "128": "mosaic-logo.svg"
    }
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Mosaic Overview"
    }
  }
}
