{
  "manifest_version": 3,
  "name": "Mosaic",
  "version": "1.0.0",
  "description": "Fast keyboard-driven tab overview interface with thumbnails",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "tabCapture",
    "favicon"
  ],
  "action": {},
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "open-overview": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Mosaic Overview"
    }
  }
}
